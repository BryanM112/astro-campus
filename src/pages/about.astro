---
import RecursoCard from "../components/RecursoCard.astro";

const titulo = "Acerca de Astro Campus";
const descripcion =
  "Proyecto incremental para aprender Astro en el contexto del curso PPW.";

const equipo = [
  { nombre: "Pablo Torres", rol: "Docente", github: "PabloT18" },
];

const modoProduccion = import.meta.env.PROD;

const herramientas = [
  {
    titulo: "Visual Studio Code",
    url: "https://code.visualstudio.com/",
    descripcion: "Editor de código",
  },
  {
    titulo: "Astro",
    url: "https://astro.build/",
    descripcion: "Framework web moderno",
  },
  {
    titulo: "GitHub",
    url: "https://github.com/",
    descripcion: "Plataforma para repositorios Git.",
  },
];

const mostrarHerramientas = herramientas.length > 0;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{titulo}</title>
  </head>
  <body>
    <main class="page">
      <h1>{titulo}</h1>
      <p>{descripcion}</p>

      <h2>Equipo</h2>
      <ul>
        {equipo.map((p) => (
          <li>
            <strong>{p.nombre}</strong> — {p.rol} ·{" "}
            <a
              href={`https://github.com/${p.github}`}
              target="_blank"
              rel="noopener"
            >
              GitHub
            </a>
          </li>
        ))}
      </ul>

      <nav>
        <a href="/">← Inicio</a>
      </nav>

      {modoProduccion ? (
        <p class="dev-status prod">Versión de producción activa.</p>
      ) : (
        <p class="dev-status dev">
          Modo desarrollo — usa <code>pnpm build</code> para producción.
        </p>
      )}

      <section>
        <h2>Herramientas</h2>

        {mostrarHerramientas ? (
          <div>
            {herramientas.map((h) => (
              <RecursoCard
                titulo={h.titulo}
                url={h.url}
                descripcion={h.descripcion}
              />
            ))}
          </div>
        ) : (
          <p>No hay herramientas disponibles.</p>
        )}
      </section>
    </main>
  </body>
</html>

<style is:global>
  body {
    font-family: system-ui, sans-serif;
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
    background: #0f0f0f;
    color: #e8e8e8;
  }

  h1 {
    color: #ff5d01;
  }

  a {
    color: #ff5d01;
  }

  li {
    margin-bottom: 0.5rem;
  }

  .page {
    display: grid;
    gap: 1rem;
  }

  .dev-status {
    font-size: 0.8rem;
  }

  .prod {
    color: #22c55e;
  }

  .dev {
    color: #f59e0b;
  }
</style>